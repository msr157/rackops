# ─────────────────────────────────────────────
# .gitignore — RackOps
# ─────────────────────────────────────────────

# Environment secrets
.env
.env.*
!.env.example

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Logs
*.log
logs/
npm-debug.log*
yarn-error.log*

# Node (if ever added)
node_modules/
dist/
build/

# Docker artifacts
*.tar

# Coverage / test
coverage/
test-results/
.nyc_output/
